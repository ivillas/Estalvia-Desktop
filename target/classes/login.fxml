<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<StackPane prefHeight="450.0" prefWidth="350.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ivillas.controller.AuthController">
   <children>
      <!-- 1. PANEL DE LOGIN -->
      <VBox fx:id="paneLogin" alignment="CENTER" spacing="15.0" style="-fx-background-color: white;">
         <children>
            <Text style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Inicia Sessió" />
            <TextField fx:id="txtUserLogin" maxWidth="250.0" promptText="Usuari" />
            <PasswordField fx:id="txtPassLogin" maxWidth="250.0" promptText="Contrasenya" />
            <Button onAction="#handleLogin" prefWidth="250.0" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="Entrar" />
            <Hyperlink onAction="#handleForgotPass" text="¿Has oblidat la contrasenya?" />
            <HBox alignment="CENTER" spacing="5.0">
               <children>
                  <Text text="¿No tens compte?" />
                  <Hyperlink onAction="#showRegister" text="Registrat aquí" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>

      <!-- 2. PANEL DE REGISTRO -->
      <VBox fx:id="paneRegister" alignment="CENTER" managed="false" spacing="15.0" style="-fx-background-color: white;" visible="false">
         <children>
            <Text style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Crear Compte" />
            <TextField fx:id="txtUserReg" maxWidth="250.0" promptText="Nom d'usuari" />
            <TextField fx:id="txtEmailReg" maxWidth="250.0" promptText="Correu electrónic (@)" />
            <PasswordField fx:id="txtPassReg" maxWidth="250.0" promptText="Contrasenya nova" />
            <Button onAction="#handleRegister" prefWidth="250.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Registrar" />
            <HBox alignment="CENTER" spacing="5.0">
               <children>
                  <Text text="¿Ja tens compte?" />
                  <Hyperlink onAction="#showLogin" text="Inicia sessió" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>

      <!-- 3. PANEL RECUPERAR (Ahora sí está dentro de children) -->
      <VBox fx:id="paneForgot" alignment="CENTER" managed="false" spacing="20.0" style="-fx-background-color: white;" visible="false">
         <children>
            <Text style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Recuperar" />
            <TextField fx:id="txtEmailForgot" maxWidth="250.0" promptText="El teu correu electrónic" />
            <Button onAction="#processRecovery" prefWidth="250.0" style="-fx-background-color: #FF9800; -fx-text-fill: white;" text="Enviar Codi" />
            <Hyperlink onAction="#showLogin" text="Tornar a l'inici" />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </children>
</StackPane>
