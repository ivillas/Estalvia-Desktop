<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="900.0" prefHeight="700.0" prefWidth="883.0" style="-fx-background-color: #F3F4F6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <center>
      <VBox spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <!-- 1. CABECERA (Se ve siempre) -->
            <HBox alignment="CENTER_LEFT" minHeight="80.0" prefHeight="80.0" prefWidth="760.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);">
               <padding>
                  <Insets left="30.0" right="30.0" />
               </padding>
               <children>
                  <Label text="Bienvenido de nuevo" textFill="#333333">
                     <font><Font name="System Bold" size="20.0" /></font>
                  </Label>
                  <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                     <children>
                        <TextField promptText="Buscar..." style="-fx-background-radius: 20; -fx-border-color: #ddd; -fx-border-radius: 20; -fx-background-color: white;" />
                        <JFXButton text="⋮" textFill="#666">
                           <font><Font size="18.0" /></font>
                        </JFXButton>
                     </children>
                  </HBox>
               </children>
            </HBox>

            <!-- 2. SCROLLPANE (Contenedor que permite bajar) -->
            <!-- VBox.vgrow="ALWAYS" hace que el scroll ocupe todo el alto restante -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
               <content>
                  <!-- 3. EL CONTENIDO (AnchorPane) -->
                  <!-- IMPORTANTE: minHeight="700" para que los botones de Y=642 sean visibles -->
                  <AnchorPane minHeight="710.0" prefWidth="850.0" style="-fx-background-color: #79EDED; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" stylesheets="@styles.css">
                     <children>
                        <TextField fx:id="txtCantidad" layoutX="649.0" layoutY="111.0" prefHeight="25.0" prefWidth="67.0" promptText="Quantitat" />
                        <TextField layoutX="49.0" layoutY="62.0" prefHeight="27.0" prefWidth="500.0" promptText="Buscar producte..." style="-fx-background-radius: 20; -fx-border-color: #ddd; -fx-border-radius: 20; -fx-background-color: white;" />
                        <JFXCheckBox layoutX="602.0" layoutY="22.0" text="Mostrar nomes productes favorits" />
                        <JFXComboBox layoutX="49.0" layoutY="106.0" prefHeight="25.0" prefWidth="500.0" />
                        
                        <!-- Lista y área de texto -->
                        <JFXListView layoutX="21.0" layoutY="220.0" prefHeight="400.0" prefWidth="520.0" />
                        <JFXTextArea layoutX="555.0" layoutY="220.0" prefHeight="291.0" prefWidth="323.0" style="-fx-background-color: white;" />
                        
                        <!-- BOTONES INFERIORES (Están en Y=642, ahora se ven bajando el scroll) -->
                        <JFXButton fx:id="btnAfegir2" layoutX="71.0" layoutY="642.0" prefHeight="34.0" prefWidth="163.0" text="Guardar llista privada" textFill="#dd0f1a" />
                        <JFXButton fx:id="btnAfegir21" layoutX="272.0" layoutY="642.0" prefHeight="34.0" prefWidth="163.0" text="Publicar llista" textFill="#dd0f1a" />
                        <JFXButton fx:id="btnAfegir31" layoutX="650.0" layoutY="603.0" prefHeight="34.0" prefWidth="197.0" text="Enviar al comparador " />
                     </children>
                  </AnchorPane>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </center>
</BorderPane>

