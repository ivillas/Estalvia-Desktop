<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXCheckBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>

<BorderPane prefHeight="700.0" prefWidth="883.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ivillas.controller.LlistesPrivadesController">
   <top>
      <AnchorPane prefHeight="80.0" style="-fx-background-color: #79EDED;">
         <children>
            <JFXCheckBox layoutX="139.0" layoutY="31.0" fx:id="checkPrivadas" onAction="#aplicarFiltro" text="Privadas" />
            <JFXCheckBox layoutX="397.0" layoutY="31.0" fx:id="checkPublicas" onAction="#aplicarFiltro" text="Públicas" />
         </children>
      </AnchorPane>
   </top>

   <center>
      <!-- IMPORTANTE: El ScrollPane en el center se estira solo -->
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
         <content>
            <FlowPane fx:id="contenedorTarjetas" hgap="20.0" prefWrapLength="800.0" vgap="20.0">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <style>-fx-background-color: white;</style>
            </FlowPane>
         </content>
      </ScrollPane>
   </center>

</BorderPane>
