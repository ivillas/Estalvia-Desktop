<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="600.0" spacing="20.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ivillas.controller.DetallController">
    <padding>
        <Insets bottom="25" left="25" right="25" top="25" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="15">
            <children>
                <VBox HBox.hgrow="ALWAYS">
                    <Label fx:id="lblTitol" style="-fx-font-weight: bold; -fx-font-size: 24; -fx-text-fill: #2C3E50;" text="Nombre de la Lista" />
                    <Label fx:id="lblAutor" style="-fx-text-fill: #7F8C8D;" text="Creado por: Usuario" />
                </VBox>
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <children>
                        <Button fx:id="btnEditarLlista" onAction="#editarLlista" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-font-weight: bold;" text="✏ Editar" />
                        <Button onAction="#tancarFinestra" style="-fx-background-color: #E74C3C; -fx-text-fill: white;" text="Cerrar" />
                    </children>
                </HBox>
            </children>
        </HBox>

        <Label fx:id="lblDescripcio" style="-fx-font-size: 14;" text="Descripción detallada aquí..." wrapText="true" />

        <TableView fx:id="taulaProductes" style="-fx-background-radius: 10;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNom" prefWidth="300.0" text="Producte" />
                <TableColumn fx:id="colQuantitat" prefWidth="100.0" text="Quantitat" />
                <TableColumn fx:id="colUnitat" prefWidth="120.0" text="Unitat" />
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT">
            <Button fx:id="btnEliminarLlista" onAction="#eliminarLlista" prefHeight="37.0" prefWidth="184.0" style="-fx-background-color: #79EDED; -fx-font-weight: bold; -fx-padding: 10 20;" text="Eliminar llista">
            <HBox.margin>
               <Insets right="120.0" />
            </HBox.margin></Button>
         <Button fx:id="btnCopiarDetall" onAction="#copiarLlista" style="-fx-background-color: #79EDED; -fx-font-weight: bold; -fx-padding: 10 20;" text="Afegir tota la llista a la meva compra" />
        </HBox>
    </children>
</VBox>