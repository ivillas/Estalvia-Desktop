<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXCheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="900.0" prefHeight="700.0" prefWidth="883.0" style="-fx-background-color: #F3F4F6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ivillas.controller.ProductesController">
   <top>
      <AnchorPane prefHeight="60.0" prefWidth="903.0" style="-fx-background-color: #79EDED; -fx-background-radius: 0 0 15 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" stylesheets="@styles.css" BorderPane.alignment="CENTER">
         <children>
            <JFXCheckBox fx:id="chbTarget" layoutX="152.0" layoutY="17.0" text="Targetes">
               <font><Font name="System Bold" size="18.0" /></font>
            </JFXCheckBox>
            <JFXCheckBox fx:id="ckbFavorit" layoutX="379.0" layoutY="17.0" text="Favorits">
               <font><Font name="System Bold" size="18.0" /></font>
            </JFXCheckBox>
            <JFXCheckBox fx:id="chbLlista" layoutX="282.0" layoutY="17.0" text="Llista">
               <font><Font name="System Bold" size="18.0" /></font>
            </JFXCheckBox>
            <Label fx:id="lblVista" layoutX="33.0" layoutY="12.0" text="Vista en:">
               <font><Font name="System Bold" size="24.0" /></font>
            </Label>
            <Label fx:id="lblTotalProductes" layoutX="498.0" layoutY="13.0" prefHeight="35.0" prefWidth="358.0" text="0">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>
   </top>
<center>
   <StackPane>
      <!-- VISTA TARGETES -->
      <ScrollPane fx:id="scrollTargetes" fitToWidth="true" style="-fx-background-color: transparent;">
         <content>
            <FlowPane fx:id="containerProductes" hgap="15.0" style="-fx-padding: 15;" vgap="15.0" />
         </content>
      </ScrollPane>

      <!-- VISTA TAuLA -->
      <TableView fx:id="tablaProductes" visible="false">
         <columns>
            <TableColumn fx:id="colNom" prefWidth="350.0" text="Producte" />
            <TableColumn fx:id="colMarca" prefWidth="150.0" text="Marca" />
            <TableColumn fx:id="colPreu" prefWidth="120.0" text="Preu Mínim" />
            <TableColumn fx:id="colAccions" prefWidth="60.0" text="" />
            <TableColumn fx:id="colAnyadir" prefWidth="60.0" text="" />
         </columns>
      </TableView>
   </StackPane>
</center>
</BorderPane>
