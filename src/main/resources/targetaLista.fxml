<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4); -fx-cursor: hand;" xmlns="http://javafx.com" xmlns:fx="http://javafx.com" fx:controller="com.ivillas.controller.TargetaController">
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
   <children>
      <Label fx:id="lblTitulo" style="-fx-font-weight: bold; -fx-font-size: 18; -fx-text-fill: #2C3E50;" text="Nombre Lista" />
      <Label fx:id="lblAutor" style="-fx-text-fill: #7F8C8D; -fx-font-style: italic;" text="por: Usuario" />
      <Label fx:id="lblDescripcion" prefHeight="40.0" wrapText="true" style="-fx-text-fill: #34495E;" text="Descripción corta..." />
      <Label fx:id="lblProductos" style="-fx-font-weight: bold; -fx-text-fill: #79EDED;" text="Productes: 0" />
      <Button fx:id="btnAfegir" maxWidth="Infinity" style="-fx-background-color: #79EDED; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text="Afegir a la meva compra" />
   </children>
</VBox>