<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<VBox fx:controller="com.ivillas.controller.ProducteItemController" 
      xmlns="http://javafx.com" xmlns:fx="http://javafx.com" 
      onMouseClicked="#abrirDetalle" alignment="CENTER" spacing="10" 
      style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
   <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
   <children>
      <ImageView fx:id="imgProducte" fitHeight="120.0" fitWidth="120.0" preserveRatio="true" />
      <Label fx:id="lblNom" style="-fx-font-weight: bold; -fx-text-fill: black;" text="Nom" wrapText="true" />
      <Label fx:id="lblPreu" style="-fx-text-fill: #2ecc71; -fx-font-weight: bold;" text="0.00 €" />
   </children>
</VBox>