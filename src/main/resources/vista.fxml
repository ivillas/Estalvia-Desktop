<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="900.0" prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #F3F4F6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ivillas.controller.MainController">
   <!-- BARRA LATERAL (Look Desktop) -->
   <left>
      <VBox fx:id="contentArea" prefHeight="700.0" prefWidth="240.0" style="-fx-background-color: #1E1E2E;" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="80.0" prefWidth="240.0" spacing="15.0">
               <padding>
                  <Insets left="20.0" />
               </padding>
               <children>
                  <AnchorPane prefHeight="40.0" prefWidth="40.0" style="-fx-background-color: #6200EE; -fx-background-radius: 10;" />
                  <Label text="Estalvia!" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <VBox prefHeight="400.0" prefWidth="117.0" spacing="10.0">
               <children>
                  <JFXButton fx:id="btnUserSession"  alignment="BASELINE_LEFT" onAction="#openLoginWindow" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0; -fx-background-color: #313144;" text="Login" textFill="WHITE">
                     <font> <Font size="14.0" /> </font>
                  </JFXButton>
                  <JFXButton alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0;" text="Llistes publiques" textFill="#a0a0a0">
                     <font> <Font size="14.0" /> </font>
                  </JFXButton>
                  <JFXButton alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0;" text="Productes" textFill="#a0a0a0">
                     <font> <Font size="14.0" /> </font>
                  </JFXButton>
                  <JFXButton alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0;" text="Les meves llistes" textFill="#a0a0a0">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </JFXButton>
                  <JFXButton alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0;" text="Crear llista" textFill="#a0a0a0">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </JFXButton>
                  <JFXButton alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0;" text="Supermercats/Proveïdors" textFill="#a0a0a0">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </JFXButton>
                  <JFXButton alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0;" text="Ayuda" textFill="#a0a0a0">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </JFXButton>
                  <JFXButton fx:id="btnLogout" onAction="#handleLogout"  visible="false" managed="false" alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0;" text="Logout" textFill="#a0a0a0">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </JFXButton>
                  <JFXButton fx:id="btnSortir" onAction="#handleExit" alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0; -fx-background-color: #313144;" text="Sortir" textFill="WHITE">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </JFXButton>
               </children>
            </VBox>
         </children>
      </VBox>
   </left>

   <!-- CUERPO PRINCIPAL -->
   <center>
      <VBox prefHeight="200.0" prefWidth="100.0" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <!-- Header Superior -->
            <HBox alignment="CENTER_LEFT" prefHeight="80.0" prefWidth="760.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);">
               <padding>
                  <Insets left="30.0" right="30.0" />
               </padding>
               <children>
                  <Label text="La teva app de compres" textFill="#333333">
                     <font> <Font name="System Bold" size="20.0" /> </font>
                  </Label>
                  <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                     <children>
                        <TextField promptText="Buscar..." style="-fx-background-radius: 20; -fx-border-color: #ddd; -fx-border-radius: 20; -fx-background-color: white;" />
                        <JFXButton prefHeight="35.0" prefWidth="35.0" text="⋮" textFill="#666">
                           <font> <Font size="18.0" /> </font>
                        </JFXButton>
                     </children>
                  </HBox>
               </children>
            </HBox>
            
            <!-- Contenedor de Tarjetas (Cards) -->
            <HBox fx:id="mainDisplayArea" prefHeight="150.0" prefWidth="760.0" spacing="20.0">
               <padding>
                  <Insets left="30.0" right="30.0" />
               </padding>
               <children>
                  <AnchorPane prefHeight="150.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" />
                  <AnchorPane prefHeight="406.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" />
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>
