<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="900.0" prefHeight="800" prefWidth="1200" style="-fx-background-color: #F3F4F6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ivillas.controller.MainController">
   <!-- BARRA LATERAL (Look Desktop) -->
   <left>
      <VBox fx:id="contentArea" prefHeight="700.0" prefWidth="240.0" style="-fx-background-color: #1E1E2E;" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="80.0" prefWidth="240.0" spacing="15.0">
               <padding>
                  <Insets left="20.0" />
               </padding>
               <children>
                  <AnchorPane prefHeight="40.0" prefWidth="40.0" style="-fx-background-color: #6200EE; -fx-background-radius: 10;" />
                 <JFXButton fx:id="btnEstalvia" onAction="#openInici" text="Estalvia!" textFill="WHITE" 
           style="-fx-background-color: transparent; -fx-cursor: hand;">
   <font>
      <Font name="System Bold" size="18.0" />
   </font>
</JFXButton>
               </children>   
            </HBox>
            <VBox prefHeight="400.0" prefWidth="117.0" spacing="10.0">
               <children>
                  <JFXButton fx:id="btnUserSession" alignment="BASELINE_LEFT" onAction="#openLoginWindow" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0; -fx-background-color: #313144;" text="Login" textFill="WHITE">
                     <font> <Font size="14.0" /> </font>
                  </JFXButton>
                  <JFXButton fx:id="btnLlistesPubliques"  onAction="#openLlistesPubliques"  alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0;" text="Llistes publiques" textFill="#a0a0a0">
                     <font> <Font size="14.0" /> </font>
                  </JFXButton>
                  <JFXButton fx:id="btnProductes" onAction="#openProductes" alignment="BASELINE_LEFT"  prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0;" text="Productes" textFill="#a0a0a0">
                     <font> <Font size="14.0" /> </font>
                  </JFXButton>
                  <JFXButton fx:id="btnLlistesPrivades"  onAction="#openLlistesPrivades" alignment="BASELINE_LEFT" managed="false" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0;" text="Les meves llistes" textFill="#a0a0a0" visible="false">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </JFXButton>
                  <JFXButton fx:id="btnCrearLlista" alignment="BASELINE_LEFT" managed="false" onAction="#openCrearLlista" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0;" text="Crear llista" textFill="#a0a0a0" visible="false">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </JFXButton>
                  <JFXButton fx:id="btnSupers" alignment="BASELINE_LEFT" managed="false" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0;" text="Supermercats/Proveïdors" textFill="#a0a0a0" visible="false">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </JFXButton>
                  <JFXButton fx:id="btnAjuda" onAction="#openAjuda" alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0;" text="Ajuda" textFill="#a0a0a0">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </JFXButton>
                  <JFXButton fx:id="btnLogout" alignment="BASELINE_LEFT" managed="false" onAction="#handleLogout" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0;" text="Logout" textFill="#a0a0a0" visible="false">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </JFXButton>
                  <JFXButton fx:id="btnSortir" alignment="BASELINE_LEFT" onAction="#handleExit" prefHeight="45.0" prefWidth="220.0" style="-fx-background-radius: 0 20 20 0; -fx-background-color: #313144;" text="Sortir" textFill="WHITE">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </JFXButton>
               </children>
            </VBox>
            <Button fx:id="btnAjustos" onAction="#openConfig" alignment="BOTTOM_RIGHT" mnemonicParsing="false" prefHeight="56.0" prefWidth="53.0" styleClass="button-ajustes" stylesheets="@styles.css">
               <VBox.margin>
                  <Insets left="150.0" top="250.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </left>
    <!-- CUERPO PRINCIPAL -->
   <center>
      <VBox prefHeight="200.0" prefWidth="100.0" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <!-- Header Superior -->
            <HBox alignment="CENTER_LEFT" prefHeight="80.0" prefWidth="760.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);">
               <padding>
                  <Insets left="30.0" right="30.0" />
               </padding>
               <children>
                  <Label fx:id="txtTitol" text="La teva app de compres" textFill="#333333">
                     <font> <Font name="System Bold" size="20.0" /> </font>
                  </Label>
                  <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                     <children>
                        <TextField fx:id="txtBuscar" promptText="Buscar..." style="-fx-background-radius: 20; -fx-border-color: #ddd; -fx-border-radius: 20; -fx-background-color: white;" />
                        <JFXButton fx:id="btnOpcions" prefHeight="35.0" prefWidth="35.0" text="⋮" textFill="#666">
                           <font> <Font size="18.0" /> </font>
                        </JFXButton>
                     </children>
                  </HBox>
               </children>
            </HBox>
            
            
            <!-- Contenedor de Tarjetas (Cards) -->
		<!-- Contenedor dinámico -->
		<StackPane fx:id="mainDisplayArea" VBox.vgrow="ALWAYS">
		   <padding>
		      <Insets bottom="20.0" left="30.0" right="30.0" />
		   </padding>
		   <!-- Aquí el controlador inyectará el ScrollPane con el FlowPane -->
		</StackPane>
         </children>
      </VBox>
   </center>
</BorderPane>
   
